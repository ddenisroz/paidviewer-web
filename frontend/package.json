{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "type-check:strict": "tsc --project tsconfig.strict.json --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "check:no-direct-tts-url": "node scripts/check-no-direct-tts-url.mjs",
    "generate-api-types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api-schema.ts",
    "preview": "vite preview",
    "fix-logs": "node scripts/replace-console-logs.js",
    "check:all": "npm run lint && npm run format:check && npm run type-check && npm run check:no-direct-tts-url",
    "test": "vitest --config vitest.config.js",
    "test:ui": "vitest --config vitest.config.js --ui",
    "test:run": "vitest run --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/pixelify-sans": "^5.2.7",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/tektur": "^5.2.7",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.31.0",
    "@sentry/tracing": "^7.120.4",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.0",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.66.0",
    "react-player": "^3.4.0",
    "react-router-dom": "^7.8.2",
    "react-use": "^17.6.0",
    "react-youtube": "^10.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.0.6",
    "ws": "^8.21.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.33.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fast-check": "^4.5.2",
    "globals": "^16.3.0",
    "jsdom": "^27.3.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.2",
    "vitest": "^4.0.16"
  }
}
