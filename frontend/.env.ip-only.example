# Vercel production env for IP-only backend.
# Keep API vars empty so browser calls same-origin Vercel rewrites.

VITE_BOT_SERVICE_URL=
VITE_API_BASE_URL=
VITE_API_URL=

# WebSocket goes through Vercel Function bridge: /api/ws/* -> ws://YOUR_SERVER_IP:8000/ws/*
VITE_BOT_SERVICE_WS_URL=wss://YOUR_VERCEL_APP_URL/api
VITE_FRONTEND_URL=https://YOUR_VERCEL_APP_URL
VITE_LOCAL_TTS_AGENT_URL=

# Server-side Vercel Function env. Do not prefix with VITE.
BOT_SERVICE_WS_TARGET=ws://YOUR_SERVER_IP:8000
