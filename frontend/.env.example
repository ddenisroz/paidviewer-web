# ===================================
# FRONTEND - ENVIRONMENT CONFIGURATION
# ===================================
# Copy this file to .env and fill in your values

# === API / WEBSOCKET ENDPOINTS ===
# In production, point these to the public bot_service domain.
# Direct Vite development is handled by vite.config.js proxy.
VITE_BOT_SERVICE_URL=http://localhost:8000
VITE_BOT_SERVICE_WS_URL=ws://localhost:8000
VITE_FRONTEND_URL=http://localhost:5173

# Optional local desktop TTS worker agent. Leave empty in production builds.
VITE_LOCAL_TTS_AGENT_URL=http://localhost:46321

# === WEBSOCKET CONNECTION LIMITS ===
VITE_WS_MAX_GLOBAL_ATTEMPTS=20
VITE_WS_RESET_INTERVAL_MS=15000
VITE_WS_MAX_RECONNECT_DELAY=5000
VITE_WS_RECONNECT_INTERVAL=1000
VITE_WS_MAX_RECONNECT_ATTEMPTS=10
VITE_WS_HEARTBEAT_INTERVAL=15000
VITE_WS_INITIAL_CONNECT_DELAY=50

# === CHAT CONFIGURATION ===
VITE_CHAT_MAX_MESSAGES=500
VITE_CHAT_ENABLE_PERSISTENCE=true
VITE_CHAT_SCROLL_BEHAVIOR=auto

# === TTS HEALTH CHECK ===
VITE_TTS_MIN_CHECK_INTERVAL=1000
VITE_TTS_FORCE_COMPLETE_TIMEOUT=3000
VITE_TTS_HEALTH_CHECK_TIMEOUT=2000
VITE_TTS_INITIAL_CHECK_DELAY=50

# === WEBSOCKET ADVANCED SETTINGS ===
VITE_WS_AGGRESSIVE_RECONNECT=true
VITE_WS_CONNECTION_TIMEOUT=10000
VITE_WS_STATUS_CHECK_INTERVAL=5000
VITE_WS_DEBUG_LOGGING=false

# === FEATURES ===
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_PERFORMANCE_MONITORING=false

# === UI SETTINGS ===
VITE_DEFAULT_THEME=dark
VITE_DEFAULT_LANGUAGE=ru
VITE_ENABLE_ANIMATIONS=true
